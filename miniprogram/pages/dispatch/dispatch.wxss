/* pages/dispatch/dispatch.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #303133;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #909399;
}

/* 派单卡片 */
.dispatch-card {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.dispatch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dispatch-badge {
  background: linear-gradient(135deg, #F56C6C, #f78989);
  color: white;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.dispatch-time {
  font-size: 24rpx;
  color: #909399;
}

.dispatch-content {
  padding: 24rpx;
}

/* 路线信息 */
.route-info {
  margin-bottom: 20rpx;
}

.route-point {
  display: flex;
  align-items: center;
}

.point-icon {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.point-icon.start {
  background: #67C23A;
}

.point-icon.end {
  background: #F56C6C;
}

.point-text {
  display: flex;
  flex-direction: column;
}

.point-label {
  font-size: 22rpx;
  color: #909399;
}

.point-address {
  font-size: 28rpx;
  color: #303133;
}

.route-line {
  display: flex;
  align-items: center;
  padding: 10rpx 0 10rpx 36rpx;
}

.distance {
  background: #f5f7fa;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #606266;
}

/* 元信息 */
.dispatch-meta {
  display: flex;
  gap: 40rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 22rpx;
  color: #909399;
}

.meta-value {
  font-size: 28rpx;
  color: #303133;
  margin-top: 4rpx;
}

/* 操作按钮 */
.dispatch-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 0;
  font-size: 30rpx;
}

.action-btn.reject {
  background: white;
  color: #909399;
  border-right: 1rpx solid #f0f0f0;
}

.action-btn.accept {
  background: white;
  color: #409EFF;
  font-weight: 500;
}

/* 详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.detail-popup {
  width: 100%;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
}

.popup-close {
  font-size: 40rpx;
  color: #909399;
  line-height: 1;
}

.popup-content {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

.detail-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  width: 140rpx;
  color: #909399;
  font-size: 26rpx;
}

.detail-value {
  flex: 1;
  color: #303133;
  font-size: 26rpx;
}

.popup-actions {
  display: flex;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.popup-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.popup-btn.reject {
  background: #f5f7fa;
  color: #606266;
  margin-right: 20rpx;
}

.popup-btn.accept {
  background: #409EFF;
  color: white;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #909399;
}