/* pages/map/map.wxss */

.map-page {
  width: 100%;
  height: 100vh;
}

/* 地图控件 */
.map-controls {
  position: absolute;
  right: 20rpx;
  top: 100rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
  font-size: 32rpx;
}

/* 订单卡片 */
.order-card {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 40rpx;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-title {
  font-size: 28rpx;
  font-weight: bold;
}

.order-status {
  background: #409EFF;
  color: white;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.order-route {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.route-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #303133;
}

.route-arrow {
  padding: 0 16rpx;
  color: #909399;
}

.order-info {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 16rpx;
}

.order-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.nav-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.nav-btn.outline {
  background: #f5f7fa;
  color: #606266;
}

.nav-btn.primary {
  background: #409EFF;
  color: white;
}

.sign-btn {
  background: #67C23A;
  color: white;
  text-align: center;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 无订单提示 */
.no-order {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.no-order-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.no-order-text {
  font-size: 32rpx;
  color: #303133;
  margin-bottom: 8rpx;
}

.no-order-hint {
  font-size: 26rpx;
  color: #909399;
}