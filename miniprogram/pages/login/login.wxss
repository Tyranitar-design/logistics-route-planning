/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #409EFF 0%, #66b1ff 100%);
  padding: 100rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 登录区域 */
.login-section {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  flex: 1;
}

/* 表单 */
.form-item {
  display: flex;
  align-items: center;
  height: 96rpx;
  background: #f5f7fa;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  padding: 0 32rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.form-item input {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  background: transparent;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #409EFF, #66b1ff);
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  margin-top: 16rpx;
}

/* 演示账号 */
.demo-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 24rpx 0;
  padding: 16rpx 0;
}

.demo-tip {
  font-size: 24rpx;
  color: #909399;
}

.demo-btn {
  font-size: 24rpx;
  color: #409EFF;
  padding: 8rpx 24rpx;
  border: 1rpx solid #409EFF;
  border-radius: 24rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.divider text {
  padding: 0 24rpx;
  color: #909399;
  font-size: 24rpx;
}

.wx-login-btn {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 协议 */
.agreement {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.agreement .link {
  color: white;
  text-decoration: underline;
}