/* pages/order-detail/order-detail.wxss */

.container {
  padding-bottom: 140rpx;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  color: var(--white);
}

.status-header {
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 26rpx;
  opacity: 0.9;
}

.status-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 8rpx;
}

.status-icon {
  font-size: 60rpx;
}

.order-no {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 步骤条 */
.steps {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.step {
  flex: 1;
  text-align: center;
}

.step-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  margin: 0 auto 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.step.finish .step-circle {
  background: #67C23A;
}

.step.process .step-circle {
  background: white;
  color: #409EFF;
}

.step-text {
  font-size: 22rpx;
  opacity: 0.8;
}

.step.finish .step-text,
.step.process .step-text {
  opacity: 1;
}

/* 地图区域 */
.map-section {
  padding: 0;
  overflow: hidden;
}

.map-actions {
  padding: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.map-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #f5f7fa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 路线信息 */
.route-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.route-card {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.route-point {
  display: flex;
  align-items: flex-start;
}

.point-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.point-icon.start {
  background: var(--success-color);
}

.point-icon.end {
  background: var(--danger-color);
}

.point-content {
  flex: 1;
}

.point-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.point-address {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-top: 4rpx;
}

.point-contact {
  margin-top: 12rpx;
  color: var(--primary-color);
  font-size: 24rpx;
}

.route-line {
  display: flex;
  align-items: center;
  padding: 20rpx 0 20rpx 40rpx;
}

.route-distance {
  background: var(--white);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  border: 1rpx dashed #ddd;
}

/* 信息列表 */
.info-section {
  margin-top: 20rpx;
}

.info-list {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.info-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.info-value {
  color: var(--text-primary);
  font-size: 26rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.btn-group .btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
}

.full-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
}

.btn-disabled {
  background: #e4e7ed;
  color: #c0c4cc;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}