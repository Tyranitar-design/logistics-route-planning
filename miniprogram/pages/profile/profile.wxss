/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  color: white;
  padding: 40rpx 30rpx;
}

.user-info {
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

.user-detail {
  margin-left: 24rpx;
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
}

.user-phone {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.user-rating {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.rating-text {
  margin-left: 16rpx;
  opacity: 0.9;
}

/* 今日数据 */
.today-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
}

.today-item {
  flex: 1;
  text-align: center;
}

.today-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.today-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.today-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 统计卡片 */
.stats-card {
  margin-top: 20rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #303133;
}

.stat-label {
  font-size: 22rpx;
  color: #909399;
  margin-top: 8rpx;
}

/* 快捷功能 */
.quick-actions {
  margin-top: 20rpx;
}

.quick-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-item {
  text-align: center;
  padding: 20rpx 10rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.quick-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

.quick-text {
  font-size: 22rpx;
  color: #606266;
}

/* 菜单卡片 */
.menu-card {
  margin-top: 20rpx;
  padding: 0;
}

.menu-item {
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 28rpx;
  color: #303133;
}

.menu-desc {
  font-size: 22rpx;
  color: #909399;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #c0c4cc;
}

/* 底部操作 */
.bottom-actions {
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.action-btn {
  text-align: center;
  padding: 24rpx;
  background: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.action-btn.logout {
  color: #F56C6C;
}