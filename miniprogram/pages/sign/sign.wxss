/* pages/sign/sign.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 20rpx;
}

.card-header .card-title {
  margin-bottom: 0;
}

.clear-btn {
  font-size: 26rpx;
  color: #909399;
}

/* 订单信息 */
.order-info {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.info-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #ebeef5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  width: 140rpx;
  color: #909399;
  font-size: 26rpx;
}

.info-row .value {
  flex: 1;
  color: #303133;
  font-size: 26rpx;
}

.info-row .phone {
  color: #409EFF;
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #606266;
  margin-bottom: 12rpx;
}

.form-label.required::before {
  content: '*';
  color: #F56C6C;
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

/* 签名区域 */
.signature-area {
  position: relative;
  background: #f5f7fa;
  border-radius: 12rpx;
  overflow: hidden;
}

.signature-canvas {
  display: block;
}

.signature-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #c0c4cc;
  font-size: 28rpx;
  pointer-events: none;
}

/* 照片区域 */
.photo-count {
  font-size: 24rpx;
  color: #909399;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.photo-add {
  width: 180rpx;
  height: 180rpx;
  background: #f5f7fa;
  border: 2rpx dashed #dcdfe6;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #909399;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #909399;
  margin-top: 8rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #67C23A, #85ce61);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}